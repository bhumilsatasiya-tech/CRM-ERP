APP_NAME="CRM-ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- Database (XAMPP MySQL by default) ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crm_erp
DB_USERNAME=crm_erp_user
DB_PASSWORD=

# ---- Module 1.1 — Auth ----
AUTH_ACCESS_TTL=1440
AUTH_REFRESH_TTL=43200
AUTH_2FA_ENABLED=false

# ---- Default super-admin (used by AdminUserSeeder) ----
ADMIN_SEED_EMAIL=admin@crm-erp.local
ADMIN_SEED_PASSWORD=ChangeMe@123

# ---- Sanctum ----
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ---- Storage abstraction (offline-first → cloud-ready) ----
FILESYSTEM_DISK=shared
SHARED_STORAGE_DRIVER=local
SHARED_STORAGE_PATH="E:/CRM+ERP/storage"

# Cloud (fill in when going online; SHARED_STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Queue / Cache / Sessions (db = portable; works offline + cloud) ----
QUEUE_CONNECTION=database
CACHE_DRIVER=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ---- Mail (SMTP) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@crm-erp.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Google Calendar (Module 6.2) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=http://localhost:8000/api/v1/tasks/calendar/callback

# ---- WhatsApp (Module 6.3 placeholder) ----
WHATSAPP_PROVIDER=placeholder
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
